---
import ProjectUnit from "./ProjectUnit.astro";
import terraza from "../../assets/renders/terraza.jpg";
import ProjectUnitFloor from "./ProjectUnitFloor.astro";
import local from "../../assets/plantas/local.jpg";

const image = {
  image: terraza,
  alt: "Imagen de la terraza de usos multiples del proyecto Nahuel Huapi 4265"
}

---

<ProjectUnit
  id="local"
  title="Local comercial"
  subtitle="Local comercial ubicado al frente, con acceso directo desde la vía pública, desarrollado en una planta y equipado con baño propio y kitchenette. Su implantación en un sector de creciente actividad urbana, a pocos metros del corredor Donado-Holmberg (DO-HO), le otorga una ubicación estratégica dentro de uno de los polos gastronómicos y comerciales más dinámicos de la zona, ofreciendo una oportunidad ideal para actividades comerciales o profesionales."
  images={[image]}
  imagePosition="object-[41%_0] 2xl:object-[41%_100%]"
>
  <ProjectUnitFloor
    isUnidades={false}
    supCub="29,50"
    supSemi="4,50"
    supTotal="34,00"
    planta={local}
    plataMobile={local}
    plantaAlt="Planta de arquitectura del Local Comercial del proyecto Nahuel Huapi 4265"
    figPosition="left-[18px] lg:left-[6px] 2xl:left-[23px]"
    variant="d"
  />
</ProjectUnit>
