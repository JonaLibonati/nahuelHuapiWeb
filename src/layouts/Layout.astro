<style>
	@reference "../styles/global.css";

	html,
	body {
		width: 100%;
		height: 100%;
	}

	@media only screen and (min-width: 1920px) {
		body .body-div {
			@apply border-stone-800 border-l-2 border-r-2
		}
	}
</style>

<style is:global>
    .vhn {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
